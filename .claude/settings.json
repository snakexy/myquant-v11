{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "LSP",
      "NotebookEdit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreToolUse\", \"additionalContext\": \"⚠️ 改代码前必读规则：\\n→ 架构约束: .claude/rules/architecture.md\\n→ 代码风格: .claude/rules/coding-style.md\\n→ 测试规范: .claude/rules/testing.md\\n\\n改任何文件前，先问用户。\"}}'"
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/scripts/plan-check.ps1 -File \"$FILE\" -Tool \"$TOOL\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/scripts/check-file-scope.ps1 -File \"$FILE\""
          },
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File .claude/scripts/check-architecture.ps1"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Speech; (New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak('please come back and confirm')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Add-Type -AssemblyName System.Speech; (New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak('Task completed')\""
          }
        ]
      }
    ]
  }
}

