              <rect x="14" y="3" width="7" height="7" rx="1" fill="#26a69a" opacity="0.6"/>
              <rect x="3" y="14" width="7" height="7" rx="1" fill="#787b86" opacity="0.6"/>
              <rect x="14" y="14" width="7" height="7" rx="1" fill="#ef5350" opacity="0.9"/>
            </svg>
