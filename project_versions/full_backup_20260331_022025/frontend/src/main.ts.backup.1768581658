  `
  document.head.appendChild(style)

  // 强制设置 HTML 元素的 color-scheme
  document.documentElement.style.colorScheme = 'dark'
  document.documentElement.style.setProperty('color-scheme', 'dark', 'important')

  // 使用 MutationObserver 监听 DOM 变化，动态修复白色背景的输入框
  const fixWhiteInputs = () => {
    // 更全面的选择器，包括 el-tooltip__trigger
    const inputWrappers = document.querySelectorAll(
      '.el-input__wrapper, ' +
      '[class*="el-input__wrapper"], ' +
      '.el-select .el-input__wrapper, ' +
      '[class*="el-select"] [class*="el-input__wrapper"], ' +
      '.timeline-controls *, ' +
      '.el-tooltip__trigger, ' +
      '[class*="el-tooltip__trigger"]'
    )
    let fixedCount = 0

    inputWrappers.forEach(wrapper => {
      // 强制设置内联样式
      wrapper.style.setProperty('background-color', 'rgba(102, 126, 234, 0.08)', 'important')
      wrapper.style.setProperty('background', 'rgba(102, 126, 234, 0.08)', 'important')
      wrapper.style.setProperty('box-shadow', 'none', 'important')
      wrapper.style.setProperty('color-scheme', 'dark', 'important')
      wrapper.style.setProperty('border-color', 'rgba(102, 126, 234, 0.3)', 'important')

      // 验证是否修复成功
      const computedStyle = window.getComputedStyle(wrapper)
      const bgColor = computedStyle.backgroundColor

      if (bgColor === 'rgb(255, 255, 255)' || bgColor === '#ffffff' || bgColor === '#fff' || bgColor === 'rgba(255, 255, 255, 1)') {
        fixedCount++
        console.log('[深色主题] 发现白色背景:', wrapper.className, '背景色:', bgColor)

        // 再次强制设置
        wrapper.setAttribute('style', `
          background-color: rgba(102, 126, 234, 0.08) !important;
          background: rgba(102, 126, 234, 0.08) !important;
          box-shadow: none !important;
          border: 1px solid rgba(102, 126, 234, 0.3) !important;
          color-scheme: dark !important;
        `)
      }
    })

    if (fixedCount > 0) {
      console.log(`[深色主题] 警告：仍有 ${fixedCount} 个输入框为白色背景`)
    }

    // 修复 Naive UI 下拉菜单
    const fixNaiveUIDropdowns = () => {
      // 查找所有可能的下拉菜单元素
      const dropdowns = document.querySelectorAll(
        '[class*="n-select-menu"], ' +
        '[class*="n-base-select-menu"], ' +
        'div[class*="select-menu"], ' +
        '.n-virtual-list, ' +
        '[class*="n-virtual-list"]'
      )

      let dropdownFixed = 0

      dropdowns.forEach(dropdown => {
        if (!(dropdown instanceof HTMLElement)) return

        const computedStyle = window.getComputedStyle(dropdown)
        const bgColor = computedStyle.backgroundColor

        // 检查是否为白色背景
        if (bgColor === 'rgb(255, 255, 255)' || bgColor === '#ffffff' || bgColor === '#fff' || bgColor === 'rgba(255, 255, 255, 1)') {
          dropdownFixed++
          console.log('[深色主题] 发现白色下拉菜单:', dropdown.className, '背景色:', bgColor)

          // 强制设置深色背景
          dropdown.style.setProperty('background-color', 'rgba(30, 41, 59, 0.98)', 'important')
          dropdown.style.setProperty('background', 'rgba(30, 41, 59, 0.98)', 'important')
          dropdown.style.setProperty('border', '1px solid rgba(100, 116, 139, 0.3)', 'important')
          dropdown.style.setProperty('backdrop-filter', 'blur(10px)', 'important')
          dropdown.style.setProperty('color-scheme', 'dark', 'important')

          // 修复所有子菜单项
          const items = dropdown.querySelectorAll('[class*="menu-item"], [class*="list-item"], [class*="option"]')
          items.forEach(item => {
            if (!(item instanceof HTMLElement)) return
            item.style.setProperty('color', '#cbd5e1', 'important')
            item.style.setProperty('background', 'transparent', 'important')
          })
        }
      })

      if (dropdownFixed > 0) {
        console.log(`[深色主题] 修复了 ${dropdownFixed} 个白色下拉菜单`)
      }
    }

    // 执行下拉菜单修复
    fixNaiveUIDropdowns()
  }

  // 立即执行一次
  setTimeout(fixWhiteInputs, 100)

  // 持续定时检查，每 200ms 检查一次（加快频率）
  setInterval(fixWhiteInputs, 200)

  const observer = new MutationObserver(() => {
    fixWhiteInputs()
  })

  // 开始观察整个 document.body
  observer.observe(document.body, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ['style', 'class']
  })

  console.log('[深色主题] MutationObserver 和定时器已启动，正在监听白色输入框...')
}

// 立即执行一次
forceDarkInputStyles()

// 在 DOM 加载后再次执行
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', forceDarkInputStyles)
} else {
  forceDarkInputStyles()
}

// 监听路由变化，确保页面切换时清理残留元素
router.afterEach(() => {
  console.log('路由变化，检查并清理残留元素')
  
  // 延迟清理，确保DOM已更新
  setTimeout(() => {
    const panels = document.querySelectorAll('.floating-panel')
    const minimizedBars = document.querySelectorAll('.minimized-panels')
    
    if (panels.length > 0) {
      console.log(`路由切换后清理 ${panels.length} 个浮动面板`)
      panels.forEach(panel => {
        if (panel.parentNode) {
          panel.parentNode.removeChild(panel)
        }
      })
    }
    
    if (minimizedBars.length > 0) {
      console.log(`路由切换后清理 ${minimizedBars.length} 个最小化面板栏`)
      minimizedBars.forEach(bar => {
        if (bar.parentNode) {
          bar.parentNode.removeChild(bar)
        }
      })
    }
  }, 100)
})