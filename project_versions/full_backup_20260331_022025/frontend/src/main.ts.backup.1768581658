      border: 1px solid #334155 !important;
      box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }

    body .n-modal .n-card,
    body [class*="n-modal"] [class*="n-card"] {
      background: #1a1a2e !important;
      border: 1px solid #334155 !important;
    }

    /* Naive UI Drawer - 统一卡片颜色 */
    body .n-drawer,
    body .n-drawer__container,
    body [class*="n-drawer"] {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
    }

    /* Naive UI Popover/Tooltip - 统一卡片颜色 */
    body .n-popover,
    body .n-tooltip,
    body [class*="n-popover"],
    body [class*="n-tooltip"] {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border: 1px solid #334155 !important;
      color: #f8fafc !important;
    }

    /* ==================== 全局统一输入框样式 ==================== */
    /* Element Plus Input/Select/DatePicker - 统一卡片颜色，与下拉菜单完全一致 */
    *.el-input__wrapper,
    *[class*="el-input__wrapper"] {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border: 1px solid #334155 !important;
      box-shadow: none !important;
      transition: all 0.3s ease !important;
    }

    *.el-input__wrapper:hover,
    *[class*="el-input__wrapper"]:hover {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border-color: rgba(139, 92, 246, 0.4) !important;
    }

    *.el-input__wrapper.is-focus,
    *[class*="el-input__wrapper"].is-focus {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border-color: #8b5cf6 !important;
      box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.1) !important;
    }

    *.el-input__inner,
    *[class*="el-input__inner"] {
      color: #f8fafc !important;
      background: transparent !important;
    }

    *.el-input__inner::placeholder,
    *[class*="el-input__inner"]::placeholder {
      color: #64748b !important;
    }

    /* Naive UI Input/Select - 统一卡片颜色，与下拉菜单完全一致 */
    body .n-input,
    body .n-base-selection,
    body [class*="n-input"],
    body [class*="n-base-selection"] {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border: 1px solid #334155 !important;
      transition: all 0.3s ease !important;
    }

    body .n-input:hover,
    body .n-base-selection:hover,
    body [class*="n-input"]:hover,
    body [class*="n-base-selection"]:hover {
      background-color: #1a1a2e !important;
      background: #1a1a2e !important;
      border-color: rgba(139, 92, 246, 0.4) !important;
    }

    body .n-input--focus,
    body .n-base-selection--active,
